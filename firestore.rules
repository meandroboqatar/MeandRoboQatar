rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the caller a signed-in admin? ──────────
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ── Leads ─────────────────────────────────────────────
    // Public users CANNOT read or write leads directly.
    // Form submissions go through /api/leads (server-side Admin SDK).
    // Only admins can read and update leads in the admin portal.
    match /leads/{docId} {
      allow read, update: if isAdmin();
      allow create, delete: if false; // server-only via Admin SDK
    }

    // ── Blog Posts ────────────────────────────────────────
    // Public users can read ONLY published posts.
    // Only admins can create, update, delete, and read drafts.
    match /posts/{docId} {
      allow read: if resource.data.status == "published"
                  || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ── Deny everything else ─────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

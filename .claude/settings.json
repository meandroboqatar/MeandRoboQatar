{
    "hooks": {
        "PostToolUse": [
            {
                "matcher": ".*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "npm run format || true"
                    },
                    {
                        "type": "command",
                        "command": "npm run lint || true"
                    }
                ]
            }
        ]
    }
}